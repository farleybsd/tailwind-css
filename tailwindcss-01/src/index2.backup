 <!--Pseudo Classes -->
  <body class="flex min-h-screen items-center justify-center bg-blue-50">
    <div class="space-y-6">
      <button
        disabled
        class="p-x-6 w-full bg-blue-500 font-semibold
             text-white duration-200 
             not-disabled:hover:scale-105 not-disabled:hover:rounded-sm not-disabled:hover:bg-blue-700 not-disabled:active:scale-75 
             disabled:cursor-not-allowed disabled:bg-gray-500"
      >
        Clique Aqui
      </button>

      <input placeholder="Digite seu nome"
      class="w-full px-4 py-2 rounded-md bg-amber-300 hover:bg-blue-600 outline-none focus:ring-2 ring-amber-300/40
      hover:focus:ring-blue-400/30">

      <div class="group bg-blue-100 rounded-xl shadow-2xl p-6">
      <div class=" font-bold text-2xl text-gray-700 group-hover:text-blue-500 w-fit">
        Titulo Do Card
      </div>
    </div>

    </div>

  </body>

  <!--Pseudo-elementos -->
<body class="bg-blue-50 min-h-screen flex items-center justify-center">
  <h2 class=" text-2xl font-bold relative before:content-['🔥'] before:absolute before:-left-8 before:top-0
              after:content-['📱'] after:absolute after:-right-6 after:top-4">
    Titulo Before And After
  </h2>

  <button class="relative mt-6 px-6 p-y-4 bg-blue-600 text-white font-bold rounded
          before:content-[''] before:absolute before:inset-0 before:bg-blue-800 before:scale-x-0
          before:origin-left before:duration-500
          hover:before:scale-x-100">Hover com efeito via before</button>
</body>
